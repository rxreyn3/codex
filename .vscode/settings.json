{
    "rust-analyzer.checkOnSave": true,
    "rust-analyzer.check.command": "clippy",
    "rust-analyzer.check.extraArgs": ["--all-features", "--tests"],
    "rust-analyzer.rustfmt.extraArgs": ["--config", "imports_granularity=Item"],
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
        "editor.formatOnSave": true,
    },
    "[toml]": {
        "editor.defaultFormatter": "tamasfe.even-better-toml",
        "editor.formatOnSave": true,
    },
    // Array order for options in ~/.codex/config.toml such as `notify` and the
    // `args` for an MCP server is significant, so we disable reordering.
    "evenBetterToml.formatter.reorderArrays": false,
    "evenBetterToml.formatter.reorderKeys": true,
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#853dcf",
        "activityBar.background": "#853dcf",
        "activityBar.foreground": "#e7e7e7",
        "activityBar.inactiveForeground": "#e7e7e799",
        "activityBarBadge.background": "#4d2f13",
        "activityBarBadge.foreground": "#e7e7e7",
        "commandCenter.border": "#e7e7e799",
        "sash.hoverBorder": "#853dcf",
        "statusBar.background": "#6c2bae",
        "statusBar.foreground": "#e7e7e7",
        "statusBarItem.hoverBackground": "#853dcf",
        "statusBarItem.remoteBackground": "#6c2bae",
        "statusBarItem.remoteForeground": "#e7e7e7",
        "titleBar.activeBackground": "#6c2bae",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#6c2bae99",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.color": "#6c2bae",
    "chatgpt.openOnStartup": true,
}
